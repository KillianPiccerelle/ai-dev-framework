{
  "hooks": [
    {
      "event": "PostToolUse",
      "matcher": "tool == \"Edit\" && (tool_input.file_path matches \"\\.(ts|tsx|js|jsx)$\")",
      "hooks": [{ "type": "command", "command": "node ~/.claude/ai-dev-framework/hooks/scripts/format-check.js \"$CLAUDE_TOOL_INPUT_FILE_PATH\"" }]
    },
    {
      "event": "PostToolUse",
      "matcher": "tool == \"Edit\" && (tool_input.file_path matches \"\\.py$\")",
      "hooks": [{ "type": "command", "command": "python3 -m ruff check \"$CLAUDE_TOOL_INPUT_FILE_PATH\" --quiet 2>/dev/null || true" }]
    },
    {
      "event": "PreToolUse",
      "matcher": "tool == \"Bash\" && (tool_input.command matches \"rm -rf|DROP TABLE|DROP DATABASE|git push --force\")",
      "hooks": [{ "type": "command", "command": "node ~/.claude/ai-dev-framework/hooks/scripts/safety-guard.js \"$CLAUDE_TOOL_INPUT_COMMAND\"" }]
    },
    {
      "event": "UserPromptSubmit",
      "hooks": [{ "type": "command", "command": "node ~/.claude/ai-dev-framework/hooks/scripts/secret-detector.js \"$CLAUDE_USER_PROMPT\"" }]
    },
    {
      "event": "Stop",
      "hooks": [{ "type": "command", "command": "node ~/.claude/ai-dev-framework/hooks/scripts/session-save.js" }]
    }
  ]
}
